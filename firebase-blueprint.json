{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "phone": { "type": "string", "description": "User's phone number" }
      },
      "required": ["name", "email"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Stock management for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the stock" },
        "initialStock": { "type": "integer", "description": "Initial number of bags" },
        "currentStock": { "type": "integer", "description": "Remaining number of bags" },
        "lowStockThreshold": { "type": "integer", "description": "Threshold for low stock alert" }
      },
      "required": ["userId", "initialStock", "currentStock"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Individual sale record",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the sale" },
        "date": { "type": "string", "format": "date-time", "description": "Date and time of the sale" },
        "bagsSold": { "type": "integer", "description": "Number of bags sold" },
        "pricePerBag": { "type": "number", "description": "Price per bag" },
        "total": { "type": "number", "description": "Total price (bagsSold * pricePerBag)" }
      },
      "required": ["userId", "date", "bagsSold", "pricePerBag", "total"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/inventory/{userId}": {
      "schema": "Inventory",
      "description": "Inventory records per user"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records"
    }
  }
}
